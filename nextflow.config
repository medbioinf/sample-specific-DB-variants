params.toolbox_image = 'variant-caller-toolbox:latest'

params {
  // Reads
  reads               = null
  ref_fasta           = null
  outdir              = 'results'

  // Reference preparation (rich bundle)
  gff3_file           = null
  use_main_chr        = true
  prebuilt_bundle     = false
  ref_fai             = null
  ref_dict            = null
  hisat2_index        = null           // dir OR .tar.gz
  gff3_filtered       = null
  gff3_filtered_tbi   = null
  cds_bed             = null

  // Variant calling
  caller              = 'bcftools'     // bcftools | gatk | freebayes
  
  // DP / ALT thresholds (defaults)
  min_dp  = 1
  min_alt = 1

  // dbSNP / rsID annotation
  dbsnp_path          = null           // file OR directory
  chrom_rename_map    = null           // optional 2-col map for --rename-chrs

  // Resources 
  threads             = 8
  remove_dups         = false          // mark by default (safer for RNA-seq)

  // Protein translation (EMBOSS transeq)
  genetic_code = 1     // NCBI table 1 by default; override with --genetic_code
}

params.mainchr_regex = '^(chr)?([0-9]{1,2}|X|Y|M|MT)$'

profiles {
  docker {
    docker.enabled = true
    process.container = params.toolbox_image
    docker.runOptions = '-u $(id -u):$(id -g)'
  }
}

