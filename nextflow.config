params.toolbox_image = 'variant-caller-toolbox:latest'   // setting the container

params {
  // Reads
  reads               = null
  ref_fasta           = null
  outdir              = 'results'

  // Reference preparation (rich bundle)
  gff3_file           = null
  use_main_chr        = true
  prebuilt_bundle     = false
  ref_fai             = null
  ref_dict            = null
  hisat2_index        = null           // dir OR .tar.gz
  gff3_filtered       = null
  gff3_filtered_tbi   = null
  cds_bed             = null

  // Variant calling
  caller              = 'bcftools'     // bcftools | gatk | freebayes
  
  // DP / ALT thresholds (defaults)
  min_dp  = 1
  min_alt = 1
  min_read_length = 35
  markdup_threads = 4

  // dbSNP / rsID annotation
  dbsnp_path          = null           // file OR directory
  chrom_rename_map    = null           // optional 2-col map for --rename-chrs

  // Resources 
  threads             = 8
  remove_dups         = false          // mark by default (safer for RNA-seq)
  fixmate_memory      = '24 GB'        // default docker memory limit for fixmate
  fixmate_cpus        = null           // override to force specific thread count
  fixmate_sort_mem    = '1G'           // per-thread samtools sort memory

  // Protein translation (EMBOSS transeq)
  genetic_code = 1     // NCBI table 1 by default; override with --genetic_code

  // RNA editing
  rna_editing = null                    // BED/TSV of editing loci (chrom  start [end])

  // Final protein DB assembly
  canonical_proteins  = null            // FASTA with reference/canonical proteins
  decoy_proteins      = null            // FASTA with decoy proteins
}

params.mainchr_regex = '^(chr)?([0-9]{1,2}|X|Y|M|MT)$'

profiles {
  docker {
    docker.enabled = true
    process.container = params.toolbox_image
    docker.runOptions = '-u $(id -u):$(id -g)'
  }
}
